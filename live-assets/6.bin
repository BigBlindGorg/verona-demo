<script>(function(){try{if("serviceWorker" in navigator){var reg=navigator.serviceWorker.register.bind(navigator.serviceWorker);if(navigator.serviceWorker.controller){navigator.serviceWorker.register=function(){return navigator.serviceWorker.ready;};try{sessionStorage.removeItem("__xr_retry");}catch(e){}return;}if(!sessionStorage.getItem("__xr_retry")){sessionStorage.setItem("__xr_retry","1");reg("/sw.js").then(function(){return navigator.serviceWorker.ready;}).then(function(){location.reload();}).catch(function(){});setTimeout(function(){try{sessionStorage.setItem("__xr_nolive","1");}catch(e){}location.replace("/index.html?xr_static=1");},4000);document.documentElement.style.visibility="hidden";try{window.stop();}catch(e){}return;}}try{sessionStorage.setItem("__xr_nolive","1");}catch(e){}location.replace("/index.html?xr_static=1");}catch(e){}})();</script>